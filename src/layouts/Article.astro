---
import Base from './Base.astro';
import { SITE, url, assetUrl, formatDate, readingTime } from '../lib/config';

interface Props {
  title: string;
  description: string;
  date: Date;
  cover?: string;
  tags?: string[];
  type?: string;
  eyebrow?: string;
  body?: string;
  backHref: string;
  backLabel: string;
}

const {
  title,
  description,
  date,
  cover,
  tags = [],
  type,
  eyebrow,
  body,
  backHref,
  backLabel,
} = Astro.props;
const mins = readingTime(body);
---

<Base title={title} description={description} ogType="article" ogImage={cover ? url(cover) : undefined}>
  <article>
    <header class="article-hero">
      <div class="container">
        <a class="back" href={backHref}>← {backLabel}</a>
        {eyebrow && <p class="month-eyebrow">{eyebrow}</p>}
        <div class="meta">
          {type && <span class="pill">{type}</span>}
          {tags.map((t) => <span class="pill">{t}</span>)}
        </div>
        <h1>{title}</h1>
        <p class="deck">{description}</p>
        <p class="byline">
          {SITE.author} · <time datetime={date.toISOString()}>{formatDate(date)}</time> ·
          {mins} min read
        </p>
      </div>
    </header>

    {
      cover && (
        <div class="container cover-wrap">
          <img class="cover" src={assetUrl(cover)} alt={title} loading="eager" />
        </div>
      )
    }

    <div class="container">
      <div class="prose">
        <slot />
      </div>

      <footer class="article-footer">
        <div class="share">
          <a
            class="btn btn-primary"
            href={SITE.telegramUrl}
            target="_blank"
            rel="noopener"
          >
            Follow on Telegram
          </a>
          <a class="btn btn-ghost" href={backHref}>More {backLabel.toLowerCase()}</a>
        </div>
        <p class="disclaimer">
          Not financial advice. Markets involve risk — always do your own research.
        </p>
      </footer>
    </div>
  </article>
</Base>

<style>
  .article-hero {
    padding: 64px 0 32px;
  }
  .article-hero .container,
  .cover-wrap,
  .article-footer {
    max-width: calc(var(--article-width) + 48px);
  }
  .back {
    display: inline-block;
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 28px;
  }
  .back:hover {
    color: var(--accent);
  }
  .month-eyebrow {
    font-size: 14px;
    font-weight: 650;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  h1 {
    font-size: clamp(34px, 5.5vw, 52px);
    margin-bottom: 18px;
  }
  .deck {
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: 20px;
    max-width: 56ch;
  }
  .byline {
    font-size: 14px;
    color: var(--text-muted);
  }
  .cover-wrap {
    margin: 16px auto 40px;
  }
  .cover {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
  }
  .article-footer {
    margin: 64px auto 0;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  .share {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .disclaimer {
    margin-top: 24px;
    font-size: 13px;
    color: var(--text-muted);
  }
</style>
