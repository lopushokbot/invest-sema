---
import { SITE, url } from '../lib/config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = url('og-default.png'),
  ogType = 'website',
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageAbs = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={url('favicon-32.png')} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={url('logo-mark.png')} />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href={url('rss.xml')} />
    <link rel="sitemap" href={url('sitemap-index.xml')} />

    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link
      rel="preload"
      href={url('fonts/InterVariable.woff2')}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={url('fonts/NewYorkExtraLarge-Semibold.woff2')}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script is:inline>
      // Theme: stored preference wins, else OS. Runs before paint — no flash.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || t === 'light') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav">
        <a class="brand" href={url('/')}>
          <img class="brand-mark" src={url('logo.png')} alt="" width="30" height="26" />
          <span class="brand-name">Invest Sema</span>
        </a>
        <div class="nav-links">
          <a href={url('longreads/')}>Long Reads</a>
          <a href={url('setups/')}>Setups</a>
          <a href={url('telegram/')}>Telegram</a>
          <a href={url('about/')}>About</a>
        </div>
        <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="4.5"></circle>
            <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8"></path>
          </svg>
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
        </button>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="footer-logo">
            <img src={url('logo.png')} alt="" width="26" height="23" />
            Invest Sema
          </span>
          <p class="footer-tag">{SITE.tagline}</p>
        </div>
        <div class="footer-links">
          <a href={url('longreads/')}>Long Reads</a>
          <a href={url('setups/')}>Weekly Setups</a>
          <a href={SITE.telegramUrl} target="_blank" rel="noopener">Telegram</a>
          <a href={url('about/')}>About</a>
          <a href={url('rss.xml')}>RSS</a>
        </div>
        <p class="footer-legal">
          Nothing here is financial advice. Do your own research. ©
          {new Date().getFullYear()} Invest Sema.
        </p>
      </div>
    </footer>

    <script is:inline>
      // Theme toggle
      document.querySelector('.theme-toggle').addEventListener('click', function () {
        var root = document.documentElement;
        var current =
          root.getAttribute('data-theme') ||
          (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        var next = current === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try {
          localStorage.setItem('theme', next);
        } catch (e) {}
      });

      // Scroll reveal
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.08 }
      );
      document.querySelectorAll('.reveal').forEach(function (el) {
        io.observe(el);
      });
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 14px 0;
    background: transparent;
  }
  .nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
  }
  .brand {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 19px;
    color: var(--text);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .brand-mark {
    width: 30px;
    height: auto;
    display: block;
  }
  .brand:hover {
    color: var(--text);
    opacity: 0.7;
  }
  .nav-links {
    justify-self: center;
    display: flex;
    gap: 26px;
    padding: 11px 24px;
    background: var(--header-bg);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    border: 1px solid var(--border);
    border-radius: 980px;
    box-shadow: var(--shadow-card);
  }
  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .nav-links a:hover {
    color: var(--text);
  }
  .theme-toggle {
    justify-self: end;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--header-bg);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    box-shadow: var(--shadow-card);
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .theme-toggle:hover {
    color: var(--accent);
  }
  .icon-moon {
    display: none;
  }
  :global(:root[data-theme='dark']) .icon-moon {
    display: block;
  }
  :global(:root[data-theme='dark']) .icon-sun {
    display: none;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .icon-moon {
      display: block;
    }
    :global(:root:not([data-theme='light'])) .icon-sun {
      display: none;
    }
  }

  main {
    min-height: 60vh;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-subtle);
    margin-top: 80px;
  }
  .footer-inner {
    padding-top: 48px;
    padding-bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 18px;
  }
  .footer-logo img {
    width: 26px;
    height: auto;
  }
  .footer-tag {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 4px;
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }
  .footer-links a {
    font-size: 14px;
    color: var(--text-secondary);
  }
  .footer-links a:hover {
    color: var(--text);
  }
  .footer-legal {
    font-size: 13px;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .nav {
      grid-template-columns: auto 1fr auto;
    }
    .nav-links {
      order: 3;
      grid-column: 1 / -1;
      justify-self: center;
      margin-top: 12px;
      gap: 18px;
      padding: 10px 18px;
    }
    .brand {
      justify-self: start;
    }
    .theme-toggle {
      justify-self: end;
    }
  }
  @media (max-width: 640px) {
    .nav-links {
      gap: 14px;
    }
    .nav-links a {
      font-size: 13px;
      white-space: nowrap;
    }
    .brand {
      font-size: 16px;
    }
  }
</style>
