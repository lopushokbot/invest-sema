---
import Base from '../layouts/Base.astro';
import { SITE, url } from '../lib/config';
---

<Base
  title="About"
  description="(Hopefully) useful thoughts about markets — macro, equities, crypto, DeFi and real-world ventures, from Sema."
>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow reveal">About</p>
      <h1 class="reveal">(Hopefully) Useful<br />thoughts about markets</h1>
    </div>
  </section>

  <section class="container narrow about-body">
    <div class="prose reveal">
      <p>
        I spend my days in financial markets: macro, equities, crypto, DeFi and real-world
        ventures.
      </p>
      <p>
        This website is for me. Here I get to express my thoughts and ideas on the markets.
        On my <a href={SITE.telegramUrl} target="_blank" rel="noopener">Telegram channel</a> I
        also post lifestyle content — in some ways connected to my work — and other thoughts
        I want to share.
      </p>
      <p>
        The content of Invest Sema is simple: <strong>one or two long reads a month</strong>
        with my overall view on the markets, plus <strong>a few setups</strong> I find
        interesting.
      </p>

      <h2>How I think</h2>
      <ul>
        <li>I'm here to grow my capital over the <strong>long term</strong> — not to chase huge Xs.</li>
        <li>I write about what I <strong>actually do</strong> with my own capital.</li>
        <li>
          My thoughts = my future actions. I take responsibility only for myself and my
          capital.
        </li>
      </ul>

      <h2>The fine print</h2>
      <p>
        Nothing here is financial advice or a recommendation to buy or sell anything. It's a
        journal of my own thinking, shared openly. Markets involve risk — always do your own
        research.
      </p>
    </div>

    <div class="projects reveal">
      <h2 class="projects-title">My small investment-related projects</h2>
      <p class="projects-sub">
        Where I go deeper — a free DeFi course, live rates and portfolio dashboards, and a
        community chat.
      </p>
      <div class="project-grid">
        <a class="card project" href={SITE.projects.defiCourse} target="_blank" rel="noopener">
          <span class="project-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v15.5H6.5A2.5 2.5 0 0 0 4 21z" />
              <path d="M4 18.5A2.5 2.5 0 0 1 6.5 16H20" />
            </svg>
          </span>
          <h3>DeFi Course</h3>
          <p>A free, hands-on course on earning extra yield on your crypto — start to finish.</p>
          <span class="project-link">Open the course →</span>
        </a>

        <a class="card project" href={SITE.projects.apyDashboard} target="_blank" rel="noopener">
          <span class="project-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 20V10M10 20V4M16 20v-7M22 20H2" />
            </svg>
          </span>
          <h3>Stablecoin APY Dashboard</h3>
          <p>Live yields across the top stablecoin protocols, refreshed daily from direct APIs.</p>
          <span class="project-link">View the dashboard →</span>
        </a>

        <a class="card project" href={SITE.projects.ruDashboard} target="_blank" rel="noopener">
          <span class="project-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="9" rx="1.5" />
              <rect x="14" y="3" width="7" height="5" rx="1.5" />
              <rect x="14" y="12" width="7" height="9" rx="1.5" />
              <rect x="3" y="16" width="7" height="5" rx="1.5" />
            </svg>
          </span>
          <h3>Russian Portfolio Dashboard</h3>
          <p>A live dashboard tracking my Russian equity portfolio, updated automatically.</p>
          <span class="project-link">View the dashboard →</span>
        </a>

        <a class="card project" href={SITE.projects.defiAlphaChat} target="_blank" rel="noopener">
          <span class="project-icon tg">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M21.9 4.6c.3-1.3-.9-2.3-2.1-1.8L2.9 9.3c-1.3.5-1.2 2.4.1 2.8l4.3 1.3 1.6 5.2c.4 1.2 1.9 1.5 2.7.6l2.4-2.5 4.4 3.2c1 .8 2.5.2 2.8-1.1l2.7-14.2zM8.2 12.5l9.8-6.1c.4-.2.7.3.4.6l-7.7 7.2-.3 3-1.5-4.7z" />
            </svg>
          </span>
          <h3>DeFi Alpha Chat</h3>
          <p>The community group — DeFi ideas, protocol picks and questions, in one place.</p>
          <span class="project-link">Join the chat →</span>
        </a>
      </div>
    </div>

    <div class="about-cta reveal">
      <a class="btn btn-primary" href={SITE.telegramUrl} target="_blank" rel="noopener">
        Follow on Telegram
      </a>
      <a class="btn btn-ghost" href={url('longreads/')}>Start with a long read</a>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding: 88px 0 40px;
  }
  .narrow {
    max-width: calc(var(--article-width) + 48px);
  }
  .page-hero h1 {
    font-size: clamp(34px, 5.4vw, 56px);
    margin-top: 12px;
    line-height: 1.12;
  }
  .about-body {
    padding-bottom: 40px;
  }
  .projects {
    margin-top: 64px;
  }
  .projects-title {
    font-size: clamp(26px, 3.4vw, 34px);
  }
  .projects-sub {
    margin-top: 10px;
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 54ch;
    line-height: 1.55;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 18px;
    margin-top: 28px;
  }
  .project {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 26px;
    color: inherit;
  }
  .project:hover {
    color: inherit;
  }
  .project-icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    margin-bottom: 4px;
  }
  .project-icon.tg {
    background: color-mix(in srgb, #2aabee 16%, transparent);
    color: #2aabee;
  }
  .project h3 {
    font-size: 19px;
  }
  .project p {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--text-secondary);
    flex: 1;
  }
  .project-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    margin-top: 4px;
  }
  .about-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 48px;
  }
</style>
