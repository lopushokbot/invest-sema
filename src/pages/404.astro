---
import Base from '../layouts/Base.astro';
import { url } from '../lib/config';
---

<Base title="Page not found">
  <section class="nf">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>This page went to cash.</h1>
      <p class="nf-sub">The link is stale or the page moved. The good stuff is still here:</p>
      <div class="nf-cta">
        <a class="btn btn-primary" href={url('/')}>Back home</a>
        <a class="btn btn-ghost" href={url('longreads/')}>Long Reads</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf {
    padding: 140px 0;
    text-align: center;
  }
  .nf h1 {
    font-size: clamp(34px, 5vw, 54px);
    margin: 14px 0 16px;
  }
  .nf-sub {
    color: var(--text-secondary);
    margin-bottom: 32px;
  }
  .nf-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
