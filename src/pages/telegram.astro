---
import Base from '../layouts/Base.astro';
import TelegramStrip from '../components/TelegramStrip.astro';
import { SITE } from '../lib/config';
import { fetchTelegramPosts } from '../lib/telegram';

const posts = await fetchTelegramPosts(9);
---

<Base
  title="Telegram"
  description="Daily investing notes and lifestyle posts on the Invest Sema Telegram channel."
>
  <section class="page-hero">
    <div class="container tg-hero">
      <div class="tg-avatar reveal">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="#ffffff">
          <path d="M21.9 4.6c.3-1.3-.9-2.3-2.1-1.8L2.9 9.3c-1.3.5-1.2 2.4.1 2.8l4.3 1.3 1.6 5.2c.4 1.2 1.9 1.5 2.7.6l2.4-2.5 4.4 3.2c1 .8 2.5.2 2.8-1.1l2.7-14.2zM8.2 12.5l9.8-6.1c.4-.2.7.3.4.6l-7.7 7.2-.3 3-1.5-4.7-.7 0z" />
        </svg>
      </div>
      <h1 class="reveal">@{SITE.telegram}</h1>
      <p class="page-sub reveal">
        The daily stream: what I'm watching, quick market reactions, and the life around
        investing. Long reads and setups get announced here first.
      </p>
      <a
        class="btn btn-primary reveal"
        href={SITE.telegramUrl}
        target="_blank"
        rel="noopener"
      >
        Subscribe on Telegram
      </a>
    </div>
  </section>

  <section class="container feed-wrap">
    <h2 class="feed-title reveal">Latest posts</h2>
    <TelegramStrip posts={posts} limit={9} />
    <p class="feed-note reveal">
      The feed refreshes with every site update — for the live channel, open Telegram.
    </p>
  </section>
</Base>

<style>
  .page-hero {
    padding: 88px 0 48px;
  }
  .tg-hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .tg-avatar {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2aabee, #229ed9);
    box-shadow: 0 8px 24px rgba(42, 171, 238, 0.35);
  }
  .tg-hero h1 {
    font-size: clamp(34px, 5vw, 52px);
  }
  .page-sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 52ch;
    line-height: 1.55;
  }
  .feed-wrap {
    padding-bottom: 40px;
  }
  .feed-title {
    font-size: 28px;
    margin-bottom: 24px;
  }
  .feed-note {
    margin-top: 24px;
    font-size: 13.5px;
    color: var(--text-muted);
  }
</style>
