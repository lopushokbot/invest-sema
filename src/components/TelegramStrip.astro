---
import { SITE, url } from '../lib/config';
import type { TgPost } from '../lib/telegram';

interface Props {
  posts: TgPost[];
  limit?: number;
}
const { posts, limit = 3 } = Astro.props;
const shown = posts.slice(0, limit);

function timeAgo(d: Date): string {
  const days = Math.floor((Date.now() - d.getTime()) / 86400000);
  if (days === 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  return months === 1 ? '1mo ago' : `${months}mo ago`;
}

function truncate(s: string, n = 220): string {
  if (s.length <= n) return s;
  return s.slice(0, n).replace(/\s+\S*$/, '') + '…';
}
---

{
  shown.length > 0 ? (
    <div class="tg-grid">
      {shown.map((p) => (
        <a class="card tg-card reveal" href={p.link} target="_blank" rel="noopener">
          <div class="tg-head">
            <span class="tg-badge">
              <img src={url('logos/telegram.png')} alt="" width="16" height="16" />
              @{SITE.telegram}
            </span>
            <span class="tg-time">{timeAgo(p.date)}</span>
          </div>
          {p.photo && (
            <div class="tg-photo">
              <img src={p.photo} alt="" loading="lazy" referrerpolicy="no-referrer" />
            </div>
          )}
          {p.text && <p class="tg-text">{truncate(p.text)}</p>}
          <div class="tg-foot">
            {p.views && <span class="tg-views">{p.views} views</span>}
            <span class="tg-open">Open in Telegram →</span>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="card tg-empty reveal">
      <p class="tg-empty-title">Live feed from Telegram</p>
      <p class="tg-empty-sub">
        Daily investing notes and the occasional slice of life — follow along on Telegram.
      </p>
      <a class="btn btn-primary" href={SITE.telegramUrl} target="_blank" rel="noopener">
        Open @{SITE.telegram}
      </a>
    </div>
  )
}

<style>
  .tg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  .tg-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px;
    color: inherit;
  }
  .tg-card:hover {
    color: inherit;
  }
  .tg-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .tg-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #2aabee;
  }
  .tg-time {
    font-size: 12.5px;
    color: var(--text-muted);
  }
  .tg-photo {
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--bg-subtle);
  }
  .tg-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tg-text {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--text);
    white-space: pre-line;
  }
  .tg-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 4px;
  }
  .tg-views {
    font-size: 12.5px;
    color: var(--text-muted);
  }
  .tg-open {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
  }
  .tg-empty {
    padding: 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .tg-empty-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
  }
  .tg-empty-sub {
    color: var(--text-secondary);
    max-width: 40ch;
    margin-bottom: 8px;
  }
</style>
