---
import { url, assetUrl, formatDate, readingTime } from '../lib/config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'longreads'>;
}
const { post } = Astro.props;
const mins = readingTime(post.body);
---

<a class="card lr-card reveal" href={url(`longreads/${post.id}/`)}>
  {
    post.data.cover && (
      <div class="lr-cover">
        <img src={assetUrl(post.data.cover)} alt={post.data.title} loading="lazy" />
      </div>
    )
  }
  <div class="lr-body">
    <div class="lr-meta">
      <time class="lr-date" datetime={post.data.date.toISOString()}>
        {formatDate(post.data.date)}
      </time>
      {post.data.tags.slice(0, 2).map((t) => <span class="pill">{t}</span>)}
    </div>
    <h3 class="lr-title">{post.data.title}</h3>
    <p class="lr-desc">{post.data.description}</p>
    <span class="lr-more">Read · {mins} min →</span>
  </div>
</a>

<style>
  .lr-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    color: inherit;
  }
  .lr-card:hover {
    color: inherit;
  }
  .lr-cover {
    aspect-ratio: 21 / 9;
    overflow: hidden;
    background: var(--bg-subtle);
  }
  .lr-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .lr-card:hover .lr-cover img {
    transform: scale(1.03);
  }
  .lr-body {
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }
  .lr-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .lr-date {
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .lr-title {
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.18;
  }
  .lr-desc {
    font-size: 16.5px;
    line-height: 1.55;
    color: var(--text-secondary);
    max-width: 60ch;
  }
  .lr-more {
    margin-top: auto;
    padding-top: 4px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--accent);
  }
  @media (max-width: 640px) {
    .lr-body {
      padding: 28px;
    }
  }
</style>
